---
import "@/styles/globals.css";
import Navbar from "@/components/layout/Navbar";
import Footer from "@/components/layout/Footer";
import { Toaster } from "@/components/ui/toaster";
import CookieConsent from "@/components/CookieConsent.astro";

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description = "Apexx Bau - Premium Pergolen & Wintergärten",
  image = "/og-image.png",
  noindex = false,
} = Astro.props;

const siteUrl = Astro.site?.toString() || "https://apexx-bau.de";
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const ogImageURL = new URL(image, siteUrl).toString();
const isProduction = process.env.CONTEXT === "production";

// Organization Schema
const organizationSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Apexx Bau",
  url: "https://apexx-bau.de",
  logo: "https://apexx-bau.de/logo.png",
  description:
    "Maßgefertigte bioklimatische Pergolen, Wintergärten und Markisen. Premium Qualität direkt vom Hersteller.",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Heidestraße 2",
    addressLocality: "Schwerte",
    postalCode: "58239",
    addressCountry: "DE",
  },
  contactPoint: {
    "@type": "ContactPoint",
    email: "info@apexx-bau.de",
    contactType: "customer service",
    availableLanguage: ["German"],
  }
});
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48x48.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta
      name="robots"
      content={(noindex || !isProduction) ? "noindex, nofollow" : "index, follow"}
    />
    <meta name="generator" content={Astro.generator} />

    <!-- Preload LCP Hero Image -->
    <link rel="preload" as="image" href={image.startsWith('/') ? image : `/images/${image}`} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:url" content={canonicalURL.toString()} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Apexx Bau" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <title>{title}</title>
    <link rel="canonical" href={canonicalURL} />
    <slot name="head" />

    <!-- Structured Data -->
    <script type="application/ld+json" is:inline set:html={organizationSchema} />
  </head>
  <body>
    <!-- 
      Navbar logic usually requires client-side state for mobile menu, 
      so we load it on client. 
    -->
    <Navbar client:load />

    <slot />

    <Footer />
    <CookieConsent />
    <Toaster client:idle />
    <script src="../lib/scroll-animation.js"></script>
  </body>
</html>
