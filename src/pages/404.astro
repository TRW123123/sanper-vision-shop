---
import Layout from "@/layouts/Layout.astro";
import { Button } from "@/components/ui/button";
---

<Layout title="Seite nicht gefunden – Apexx Bau" noindex={true}>
  <main class="min-h-[70vh] flex items-center justify-center">
    <div class="container max-w-2xl text-center py-20">
      <p class="text-7xl font-bold text-primary/20 mb-4">404</p>
      <h1 class="text-3xl font-bold mb-4">Seite nicht gefunden</h1>
      <p class="text-muted-foreground mb-10 text-lg">
        Die gesuchte Seite existiert nicht oder wurde verschoben.
        Vielleicht finden Sie hier, was Sie suchen:
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
        <Button size="lg" asChild>
          <a href="/">Zur Startseite</a>
        </Button>
        <Button size="lg" variant="outline" asChild>
          <a href="/produkte/">Produkte ansehen</a>
        </Button>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-left">
        <a href="/pergola-systeme/" class="p-4 rounded-xl border border-border hover:border-primary/40 transition-colors">
          <p class="font-semibold mb-1">Pergola-Systeme</p>
          <p class="text-sm text-muted-foreground">Lamellendächer & bioklimatische Pergolen</p>
        </a>
        <a href="/wintergarten-systeme/" class="p-4 rounded-xl border border-border hover:border-primary/40 transition-colors">
          <p class="font-semibold mb-1">Verglasungssysteme</p>
          <p class="text-sm text-muted-foreground">Glasschiebewände & Wintergärten</p>
        </a>
        <a href="/zip-screen-systeme/" class="p-4 rounded-xl border border-border hover:border-primary/40 transition-colors">
          <p class="font-semibold mb-1">Textile Beschattung</p>
          <p class="text-sm text-muted-foreground">ZIP-Screens & Senkrechtmarkisen</p>
        </a>
      </div>
    </div>
  </main>
</Layout>
