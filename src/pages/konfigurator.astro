---
import Layout from "@/layouts/Layout.astro";
import { Configurator } from "@/components/configurator/Configurator";
---

<Layout 
  title="Traumgarten Konfigurator - Apexx Bau"
  description="Konfigurieren Sie Ihre individuelle Pergola, Wintergarten oder Markise in wenigen Schritten."
>
  <main class="min-h-screen bg-muted/30">
    <div class="container py-6 lg:py-10">
      <div class="text-center max-w-3xl mx-auto mb-6">
        <h1 class="text-3xl lg:text-4xl font-bold mb-3">
          Ihr Projekt in 6 Schritten
        </h1>
        <p class="text-base text-muted-foreground">
          Maßgeschneidertes Angebot — unverbindlich und kostenlos.
        </p>
      </div>
      
      {/* Hidden Netlify Form for Detection */}
      <form name="konfigurator" data-netlify="true" netlify-honeypot="bot-field" hidden>
        <input type="text" name="category" />
        <input type="text" name="productId" />
        <input type="text" name="width" />
        <input type="text" name="projection" />
        <input type="text" name="height" />
        <input type="text" name="situation" />
        <input type="text" name="color" />
        <input type="text" name="extras" />
        <input type="text" name="firstName" />
        <input type="text" name="lastName" />
        <input type="email" name="email" />
        <input type="text" name="phone" />
        <input type="text" name="zip" />
        <textarea name="message"></textarea>
        <input type="text" name="priceMin" />
        <input type="text" name="priceMax" />
      </form>

      <Configurator client:load />
    </div>
  </main>
</Layout>
