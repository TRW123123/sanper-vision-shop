---
import Layout from "@/layouts/Layout.astro";
import ReferenzenView from "@/components/pages/ReferenzenView";
import CSVContentBlocks from "@/components/csv/CSVContentBlocks.astro";

const pageContent = {
  block_1_content: "Referenzprojekte zeigen, wie Systeme in der Praxis genutzt werden. Diese Seite hilft, eigene Anforderungen mit realen Projekten abzugleichen.",
  block_1_placement: "after_intro",
  block_2_content: "Risiken entstehen, wenn Referenzen nicht vergleichbar sind oder wichtige Details fehlen.",
  block_2_placement: "before_cta",
};
---

<Layout
  title="Referenzen - Apexx Bau"
  description="Referenzprojekte von Apexx Bau: Pergolen, Wintergärten und ZIP-Screens für Wohnbau, Gastronomie und Gewerbe. Reale Projekte, reale Ergebnisse."
>
  <CSVContentBlocks
    block_1_content={pageContent.block_1_content}
    block_1_placement={pageContent.block_1_placement}
    block_2_content={pageContent.block_2_content}
    block_2_placement={pageContent.block_2_placement}
    targetPlacement="after_intro"
  />

  <ReferenzenView client:load />

  <CSVContentBlocks
    block_1_content={pageContent.block_1_content}
    block_1_placement={pageContent.block_1_placement}
    block_2_content={pageContent.block_2_content}
    block_2_placement={pageContent.block_2_placement}
    targetPlacement="before_cta"
  />
</Layout>
